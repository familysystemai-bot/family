# انسخ هذا الملف إلى `.env` واملأ القيم. لا ترفع `.env` إلى git (موجود في .gitignore).
#
# إلزامي للتشغيل (انظر config.py):
# SECRET_KEY=سلسلة_عشوائية_طويلة
# ADMIN_PASSWORD=...
# FOUNDER_PASSWORD=...
# FOUNDER_USERNAME=...   (اختياري، الافتراضي kazm)
# ADMIN_USERNAME=...    (اختياري)
# DEFAULT_BRANCH_PASSWORD=...  — عند أول تشغيل وقاعدة فارغة: لبذر فروع افتراضية (SQLite أو Postgres)
#
# ─── قاعدة البيانات (يُفضّل PostgreSQL مُدار — Neon / Supabase / Render Postgres / إلخ) ───
# إذا عُيّن DATABASE_URL بصيغة postgres، يُستخدم PostgreSQL تلقائياً حتى بدون DB_TYPE.
#
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
# اختياري إن لم يكن الـ URL واضحاً:
# DB_TYPE=postgres
#
# للتطوير المحلي فقط (ملف تحت data/): اترك DATABASE_URL فارغاً ويمكنك وضع DB_TYPE=sqlite
# لرفض SQLite نهائياً على أي سيرفر: DATABASE_REQUIRE_POSTGRES=true
#
# واتساب (إن استخدمت سكربت whatsapp_sender.py أو الإنتاج):
# WA_ACCESS_TOKEN=
# WA_PHONE_NUMBER_ID=
# WA_TEST_RECIPIENT=9665xxxxxxxx
# META_APP_SECRET=
#
# OpenAI — الأولوية: OPENAI_API_KEY من البيئة؛ عند فشل الطلب يُجرّب المفتاح المسجّل في لوحة التحكم (نفس المفتاح في system_settings).

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o
